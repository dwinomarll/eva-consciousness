# Copy to .env and fill in your keys
ANTHROPIC_API_KEY=
NOTION_TOKEN=
OMI_API_KEY=
PORT=3000

# Tether: set a token to require `Authorization: Bearer <token>` on POST /chat
# and on the remote MCP endpoint (npm run mcp:http). Leave blank for local only.
EVA_AUTH_TOKEN=

# Override the shared memory root (defaults to ~/eva-workspace).
# EVA_WORKSPACE=

# ── Slack MCP ─────────────────────────────────────────────────────
# Create a Slack app, add a bot token, find your team (workspace) ID.
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ── Google Calendar MCP ───────────────────────────────────────────
# Path to your Google OAuth client credentials JSON (gcp-oauth.keys.json).
GOOGLE_OAUTH_CREDENTIALS=

# ── Gmail MCP ─────────────────────────────────────────────────────
# One-time auth (stores creds in ~/.gmail-mcp/):
#   npx @gongrzhe/server-gmail-autoauth-mcp auth
# Optional: point at your OAuth keys file if not in the default location.
# GMAIL_OAUTH_PATH=
