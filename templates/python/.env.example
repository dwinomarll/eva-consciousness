# Copy to .env and fill in your keys
ANTHROPIC_API_KEY=
NOTION_TOKEN=
OMI_API_KEY=

# Tether: set a token to require `Authorization: Bearer <token>` on POST /chat.
# Leave blank to run open (local only).
EVA_AUTH_TOKEN=

# Override the shared memory root (defaults to ~/eva-workspace).
# EVA_WORKSPACE=

# ── Semantic memory (optional) ────────────────────────────────────
# eva_recall works offline by default (BM25 keyword ranking). Add an
# embeddings key to upgrade recall to true vector/semantic search — new
# memories are embedded as they're written. Voyage or OpenAI work as-is:
# VOYAGE_API_KEY=
# OPENAI_API_KEY=
# …or point at any OpenAI-compatible embeddings endpoint:
# EVA_EMBED_API_KEY=
# EVA_EMBED_URL=https://api.voyageai.com/v1/embeddings
# EVA_EMBED_MODEL=voyage-3.5

# ── Slack MCP ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ── Google Calendar MCP ───────────────────────────────────────────
GOOGLE_OAUTH_CREDENTIALS=

# ── Gmail MCP ─────────────────────────────────────────────────────
# One-time auth: npx @gongrzhe/server-gmail-autoauth-mcp auth
# GMAIL_OAUTH_PATH=
